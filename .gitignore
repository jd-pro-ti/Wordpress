# WordPress core files (no deben subirse al repo)
/wp-admin/
/wp-includes/
/wp-content/plugins/
/wp-content/themes/twenty*/  # Temas por defecto (opcional)
/wp-content/uploads/
/wp-content/cache/
/wp-content/upgrade/
/wp-content/languages/

# WordPress root files (solo los necesarios)
/index.php
/wp-activate.php
/wp-blog-header.php
/wp-comments-post.php
/wp-cron.php
/wp-links-opml.php
/wp-load.php
/wp-mail.php
/wp-settings.php
/wp-signup.php
/wp-trackback.php
/xmlrpc.php

# Configuración sensible
/wp-config.php
/wp-config-sample.php
/.htaccess
/.htpasswd

# Archivos de documentación
/license.txt
/readme.html

# Archivos de log y caché
*.log
*.cache
*.tmp
*.bak
*.old

# Archivos de entorno y configuración local
.env
.env.local
.env.*.local

# Dependencias (si usas Composer o NPM)
/vendor/
/node_modules/
/composer.lock
/package-lock.json

# Archivos de IDE y sistema
.DS_Store
.idea/
.vscode/
*.sublime-*
Thumbs.db
*.swp
*.swo

# Archivos de compresión (si generas backups en el root)
*.zip
*.tar.gz
*.sql
*.sql.gz

# Archivos específicos de WP CLI
wp-cli.local.yml

# MySQL y bases de datos
*.sql
*.myi
*.myd
*.frm

# Archivos de depuración
debug.log
error_log
php_errors.log

# Archivos de optimización de WordPress
advanced-cache.php
object-cache.php
db.php
install.php