    "styles": {
        "spacing": {
            "blockGap": "1.2rem"
        },
        "blocks": {
            "core/post-content": {
                "spacing": {
                    "margin": {
                        "top": "0px"
                    }
                }
            },
            "core/quote": {
                "color": {
                    "text": "var(--wp--preset--color--gv-color-dark-text-secondary)",
                    "background": "var(--wp--preset--color--gv-color-dark-background-primary)"
                },
                "elements": {
                    "link": {
                        "color": {
                            "text": "var(--wp--preset--color--gv-color-dark-text-secondary)"
                        }
                    },
                    "heading": {
                        "color": {
                            "text": "var(--wp--preset--color--white)"
                        }
                    }
                },
                "typography": {
                    "fontSize": "var:preset|font-size|medium"
                },
                "spacing": {
                    "padding": {
                        "top": "48px",
                        "bottom": "48px",
                        "left": "48px",
                        "right": "48px"
                    },
                    "margin": {
                        "right": "0px",
                        "left": "0px"
                    }
                }
            }
        },
        "color": {
            "background": "var(--wp--preset--color--gv-color-black)",
            "text": "var(--wp--preset--color--gv-color-dark-text-secondary)"
        },
        "elements": {
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--gv-color-dark-primary)"
                },
                ":hover": {
                    "color": {
                        "text": "var(--wp--preset--color--gv-color-dark-secondary)"
                    }
                }
            },
            "button": {
                "color": {
                    "text": "var(--wp--preset--color--white)",
                    "background": "var(--wp--preset--color--gv-color-dark-secondary)"
                }
            },
            "heading": {
                "color": {
                    "text": "var(--wp--preset--color--white)"
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--dm-sans)",
                    "fontStyle": "normal",
                    "fontWeight": "600"
                }
            }
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--dm-sans)"
        }
    },
    "templateParts": [
        {
            "area": "header",
            "name": "header"
        },
        {
            "area": "footer",
            "name": "footer"
        }
    ],
    "version": 2
}